{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "outDir": "./dist",
        "rootDir": "./src",
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noEmitOnError": false
    },
    "include": [
        "src/**/*"
    ]
}