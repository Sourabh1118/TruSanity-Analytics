# ================================================
# Netra Analytics — Environment Variables
# Copy this file to .env and fill in your values
# ================================================

# ── App ──────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Database (PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://netra:netra_secret@localhost:5432/netra_db

# ── ClickHouse ────────────────────────────────────
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DB=netra
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=netra-ingestion
KAFKA_GROUP_ID=netra-clickhouse-consumer

# ── Auth (NextAuth.js) ────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_super_secret_nextauth_key_here
AUTH_URL=http://localhost:3000

# Google OAuth (optional for local dev)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (optional for local dev)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Email (Resend) ─────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ── Stripe Billing ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_pub_key

# ── Ingestion API ─────────────────────────────────
INGESTION_API_PORT=3001
INGESTION_RATE_LIMIT_EVENTS=1000
INGESTION_RATE_LIMIT_WINDOW_SECONDS=60
